# 默认使用可复现的模拟行情；可选 mock / akshare / tushare
MARKET_DATA_PROVIDER=mock

# 仅当 MARKET_DATA_PROVIDER=tushare 时在本地 .env 中填写，切勿提交真实 Token
TUSHARE_TOKEN=

# 仅当 MARKET_DATA_PROVIDER=ifind 时填写。使用 iFinD HTTP API 的 refresh_token；
# 不要提交到 Git、发送到前端或粘贴到聊天记录。
IFIND_REFRESH_TOKEN=
IFIND_BASE_URL=https://quantapi.51ifind.com/api/v1

REQUEST_TIMEOUT_SECONDS=8
REQUEST_RETRIES=2
QUOTE_CACHE_SECONDS=5
HISTORY_CACHE_SECONDS=300
WEBSOCKET_INTERVAL_SECONDS=3
WATCHLIST_FILE=data/watchlist.json
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 第一阶段不会加载任何下单模块；该值必须保持 false
TRADING_ENABLED=false
